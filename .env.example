# ============================================================================
# Evergrow Landscaping - Environment Variables Template
# ============================================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control (already in .gitignore)
#
# For Cloudflare Pages/Workers production secrets, use:
#   wrangler secret put <KEY_NAME>
# ============================================================================

# ----------------------------------------------------------------------------
# STRIPE - Payment Processing
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/test/apikeys (test)
#           https://dashboard.stripe.com/apikeys (live)
#
# Use TEST keys for development and staging
# Use LIVE keys only in production after Stripe account is fully verified

# Frontend (Next.js) - safe to expose, starts with pk_test_ or pk_live_
# NOTE: These must match exactly — the code reads these specific names
NEXT_PUBLIC_STRIPE_PUBLISHABLE_EVERGROW_TEST=pk_test_YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_EVERGROW_LIVE=pk_live_YOUR_KEY_HERE

# Backend (Cloudflare Worker secret) - NEVER expose publicly, set via wrangler secret put
# wrangler secret put EVERGROW_STRIPE_SECRET_KEY_TEST
EVERGROW_STRIPE_SECRET_KEY_TEST=sk_test_YOUR_KEY_HERE
# wrangler secret put EVERGROW_STRIPE_SECRET_KEY_LIVE
EVERGROW_STRIPE_SECRET_KEY_LIVE=sk_live_YOUR_KEY_HERE

# Webhook signing secrets - one per endpoint in Stripe Dashboard > Webhooks
# wrangler secret put EVERGROW_STRIPE_WEBHOOK_SECRET_TEST
EVERGROW_STRIPE_WEBHOOK_SECRET_TEST=whsec_YOUR_TEST_SECRET_HERE
# wrangler secret put EVERGROW_STRIPE_WEBHOOK_SECRET_LIVE
EVERGROW_STRIPE_WEBHOOK_SECRET_LIVE=whsec_YOUR_LIVE_SECRET_HERE

# ----------------------------------------------------------------------------
# RESEND - Transactional Email
# ----------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE

# ----------------------------------------------------------------------------
# SESSION / AUTH
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING

# ----------------------------------------------------------------------------
# NOTIFICATIONS
# ----------------------------------------------------------------------------
# Internal notifications email (receives contact forms, quote requests, etc.)
# contact@evergrowlandscaping.com is the public alias; set this to the real inbox
NOTIFICATION_EMAIL=karson@evergrowlandscaping.com

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
# Values: "test" | "production"
# Controls Stripe mode and other environment-specific behavior
ENVIRONMENT=test
